{
  "manifest_version": 3,
  "name": "ドラッグ＆ドロップコメント",
  "version": "1.0.0",
  "description": "ニコニコ動画の動画ページ上で定型コメントをコメント入力欄へドラッグ＆ドロップすることでコメントをできるようにする拡張機能です",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.nicovideo.jp/watch/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
